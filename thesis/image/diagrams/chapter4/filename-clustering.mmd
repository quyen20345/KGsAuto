flowchart LR
    Corpus["Markdown corpus"]:::input

    subgraph Grouping["Document grouping"]
        direction TB
        Sim["Filename similarity"]:::process
        Clusters["Related document clusters"]:::artifact
        Sim --> Clusters
    end

    subgraph ClusterA["One document cluster"]
        direction TB
        D1["Document 1"]:::input
        D2["Document 2"]:::input
        D3["Document 3"]:::input
        LC["Local context state<br/>entities + aliases + recent facts"]:::context
        D1 --> LC
        LC --> D2
        D2 --> LC
        LC --> D3
        D3 --> LC
    end

    subgraph Extraction["Context-aware extraction"]
        direction TB
        Prompt["Prompt with<br/>document + local context"]:::process
        Fragment["Graph fragments<br/>with local consistency"]:::artifact
    end

    Island["Local island graph"]:::graphEvidence
    ER["Entity Resolution<br/>global duplicate resolution"]:::answer

    Corpus --> Sim
    Clusters --> ClusterA
    LC --> Prompt
    Prompt --> Fragment
    Fragment --> Island
    Island --> ER

    Note["Purpose: reduce local fragmentation<br/>before global Entity Resolution"]:::note
    Note -.-> LC
    Note -.-> ER

    classDef input fill:#E3F2FD,stroke:#1565C0,color:#0D47A1;
    classDef process fill:#EDE7F6,stroke:#5E35B1,color:#311B92;
    classDef context fill:#FCE4EC,stroke:#C2185B,color:#880E4F;
    classDef graphEvidence fill:#FFF3E0,stroke:#FB8C00,color:#5D4037;
    classDef artifact fill:#FAFAFA,stroke:#757575,color:#212121,stroke-dasharray:5 3;
    classDef note fill:#EEEEEE,stroke:#616161,color:#212121,stroke-dasharray:5 3;
    classDef answer fill:#C8E6C9,stroke:#2E7D32,color:#1B5E20;
