flowchart TD
    subgraph Input["Input data"]
        MD["Markdown documents<br/>UET public data"]:::input
    end

    subgraph Extraction["KG extraction"]
        LLM["LLM extraction<br/>schema-guided prompt"]:::process
        FRAG["Graph fragments<br/>nodes + relationships + provenance"]:::artifact
    end

    subgraph Quality["Graph quality layer"]
        ER["Entity Resolution<br/>canonical entity + rewiring"]:::process
        CG["Resolved graph"]:::graphEvidence
    end

    subgraph Storage["Storage layer"]
        NEO[("Neo4j<br/>Knowledge Graph")]:::store
        QDR[("Qdrant<br/>Markdown vectors")]:::store
    end

    subgraph Retrieval["Retrieval and QA layer"]
        SS["Semantic Search"]:::textMode
        NGR["Naive Graph RAG"]:::graphMode
        GS["Graph Search"]:::graphMode
        HYB["Hybrid RAG"]:::hybridMode
    end

    subgraph Apps["Application layer"]
        CAPI["apps/chat_api<br/>Chat API"]:::api
        GAPI["apps/graph_api<br/>Graph API"]:::api
        FE["Frontend<br/>React/Vite"]:::answer
    end

    MD --> LLM
    LLM --> FRAG
    FRAG --> ER
    ER --> CG
    CG --> NEO
    MD -. "chunk + embed" .-> QDR

    QDR --> SS
    NEO --> NGR
    NEO --> GS
    SS --> HYB
    GS --> HYB

    SS --> CAPI
    NGR --> CAPI
    GS --> CAPI
    HYB --> CAPI
    NEO --> GAPI
    CAPI --> FE
    GAPI --> FE

    classDef input fill:#E3F2FD,stroke:#1565C0,color:#0D47A1;
    classDef process fill:#EDE7F6,stroke:#5E35B1,color:#311B92;
    classDef textMode fill:#E8F5E9,stroke:#2E7D32,color:#1B5E20;
    classDef graphMode fill:#FFF8E1,stroke:#F9A825,color:#5D4037;
    classDef hybridMode fill:#FCE4EC,stroke:#C2185B,color:#880E4F;
    classDef graphEvidence fill:#FFF3E0,stroke:#FB8C00,color:#5D4037;
    classDef store fill:#EEEEEE,stroke:#616161,color:#212121;
    classDef artifact fill:#FAFAFA,stroke:#757575,color:#212121,stroke-dasharray:5 3;
    classDef api fill:#E0F7FA,stroke:#00838F,color:#006064;
    classDef answer fill:#C8E6C9,stroke:#2E7D32,color:#1B5E20;
