flowchart TB
    A["Candidate cluster<br/>from Stage 2"]:::input --> B["Pass 1<br/>Split into merge candidates"]:::process

    B --> C["Candidate merge group"]:::group
    B --> N["Not enough relation<br/>keep as separate entities"]:::guard

    C --> D["Confidence check<br/>name/alias + embedding + provenance"]:::guard
    D -->|"strong evidence"| E["Pass 2<br/>Create canonical entity"]:::process
    D -->|"weak evidence"| N

    E --> F["Canonical entity<br/>standard name + aliases + provenance"]:::artifact
    N --> G["Original entities<br/>kept unchanged"]:::artifact

    F --> H["Graph rewiring<br/>relationships point to canonical IDs"]:::process
    G --> H
    H --> O["Resolved graph"]:::answer

    classDef input fill:#E3F2FD,stroke:#1565C0,color:#0D47A1;
    classDef process fill:#EDE7F6,stroke:#5E35B1,color:#311B92;
    classDef group fill:#FFF3E0,stroke:#FB8C00,color:#5D4037;
    classDef guard fill:#FFF8E1,stroke:#F9A825,color:#5D4037;
    classDef artifact fill:#FAFAFA,stroke:#757575,color:#212121,stroke-dasharray:5 3;
    classDef answer fill:#C8E6C9,stroke:#2E7D32,color:#1B5E20;
