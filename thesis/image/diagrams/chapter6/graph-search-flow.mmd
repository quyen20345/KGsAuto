flowchart LR
    Q["User question"]:::input

    subgraph Prep["Context preparation"]
        direction TB
        IR["Initial Retriever<br/>Neo4j + Qdrant"]:::process
        ISUM["Initial summaries<br/>text + KG"]:::artifact
        IR --> ISUM
    end

    subgraph Semantic["Semantic branch"]
        direction TB
        SD["Semantic Decomposer"]:::textMode
        SLOOP["Sub-query loop<br/>grounding → retrieve<br/>filter text → refine<br/>→ intermediate answer"]:::process
        SDraft["Logic Drafter"]:::process
        SVer["Evidence Verifier"]:::process
        SExp["Query Expander"]:::hybridMode
        SD --> SLOOP
        SLOOP --> SDraft
        SDraft --> SVer
        SVer -. "insufficient evidence" .-> SExp
        SExp -. "additional context" .-> SLOOP
    end

    subgraph Relational["Relational branch"]
        direction TB
        RD["Relational Decomposer"]:::graphMode
        RLOOP["Sub-query loop<br/>grounding → retrieve<br/>filter KG → refine<br/>→ intermediate answer"]:::process
        RDraft["Logic Drafter"]:::process
        RVer["Evidence Verifier"]:::process
        RExp["Query Expander"]:::hybridMode
        RD --> RLOOP
        RLOOP --> RDraft
        RDraft --> RVer
        RVer -. "insufficient evidence" .-> RExp
        RExp -. "additional context" .-> RLOOP
    end

    FS["Final Synthesiser"]:::process
    A["Answer<br/>+ reasoning<br/>+ evidence"]:::answer

    Q --> IR
    ISUM --> SD
    ISUM --> RD
    SDraft --> FS
    RDraft --> FS
    FS --> A

    classDef input fill:#E3F2FD,stroke:#1565C0,color:#0D47A1;
    classDef process fill:#EDE7F6,stroke:#5E35B1,color:#311B92;
    classDef textMode fill:#E8F5E9,stroke:#2E7D32,color:#1B5E20;
    classDef graphMode fill:#FFF8E1,stroke:#F9A825,color:#5D4037;
    classDef hybridMode fill:#FCE4EC,stroke:#C2185B,color:#880E4F;
    classDef artifact fill:#FAFAFA,stroke:#757575,color:#212121,stroke-dasharray:5 3;
    classDef store fill:#EEEEEE,stroke:#616161,color:#212121;
    classDef answer fill:#C8E6C9,stroke:#2E7D32,color:#1B5E20;
