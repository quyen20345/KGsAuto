# ── Neo4j ────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# ── Qdrant ───────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── LLM provider defaults ────────────────────────────────────────────────
LLM_PROVIDER=OpenAICompatible
LLM_MODEL=cx/gpt-5.3-codex

# ── OpenAI-compatible provider ───────────────────────────────────────────
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=http://localhost:20128/v1
OPENAI_COMPATIBLE_MODEL=cx/gpt-5.3-codex

# ── Gemini provider ──────────────────────────────────────────────────────
GOOGLE_API_KEY=
DEFAULT_MODEL=gemini-2.5-flash

# ── Embedding ────────────────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIM=768
EMBEDDING_DEVICE=cpu

# ── RAG data paths & collections ─────────────────────────────────────────
RAG_MARKDOWN_DIR=data/raw/uet
RAG_OUTPUT_DIR=data/rag_system
RAG_MARKDOWN_COLLECTION=rag_markdown_chunks
RAG_ENTITY_COLLECTION=rag_entities

# ── RAG chunking ─────────────────────────────────────────────────────────
RAG_CHUNK_STRATEGY=section
RAG_CHUNK_MAX_TOKENS=100
RAG_CHUNK_OVERLAP_TOKENS=20
RAG_CHUNK_MIN_TOKENS=15

# ── GraphSearch tuning ───────────────────────────────────────────────────
GRAPH_KEYWORD_MAX_TERMS=12
GRAPH_KEYWORD_TIMEOUT_SECONDS=60.0
GRAPHSEARCH_MAX_SUB_QUERIES=5
GRAPHSEARCH_MAX_EXPANDED_QUERIES=3

# ── Evaluation ───────────────────────────────────────────────────────────
RAGAS_SCORE_MAX_WORKERS=2
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
CX_API_KEY=
