# KGsAuto backend/services environment example.
# Copy to .env for local backend/service development. Do not expose this file to the frontend.

# ── Config behavior ────────────────────────────────────────────────────────
CONFIG_STRICT=false

# ── Neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# ── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── LLM provider defaults ──────────────────────────────────────────────────
LLM_PROVIDER=OpenAICompatible
LLM_MODEL=cx/gpt-5.3-codex

# ── OpenAI-compatible provider ─────────────────────────────────────────────
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=http://localhost:20128/v1
OPENAI_COMPATIBLE_MODEL=cx/gpt-5.3-codex

# ── Gemini provider ────────────────────────────────────────────────────────
# GOOGLE_API_KEY=
# DEFAULT_MODEL=gemini-2.5-flash

# ── Embedding ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIM=768
EMBEDDING_DEVICE=cpu

# ── RAG data paths & collections ───────────────────────────────────────────
RAG_MARKDOWN_DIR=data/raw/uet
RAG_OUTPUT_DIR=data/rag_system
RAG_MARKDOWN_COLLECTION=rag_markdown_chunks
RAG_ENTITY_COLLECTION=rag_entities

# ── RAG chunking ───────────────────────────────────────────────────────────
RAG_CHUNK_STRATEGY=section
RAG_CHUNK_MAX_TOKENS=100
RAG_CHUNK_OVERLAP_TOKENS=20
RAG_CHUNK_MIN_TOKENS=15

# ── GraphSearch tuning ─────────────────────────────────────────────────────
GRAPH_KEYWORD_MAX_TERMS=16
GRAPH_KEYWORD_TIMEOUT_SECONDS=60.0
GRAPH_FULLTEXT_CANDIDATE_LIMIT=50
GRAPH_NEIGHBOR_LIMIT_PER_ENTITY=10
GRAPH_FULLTEXT_ENTITY_INDEX=kg_entity_search
GRAPH_FULLTEXT_RELATIONSHIP_INDEX=kg_relationship_search
GRAPH_ENABLE_RELATIONSHIP_FULLTEXT=true
GRAPH_ENABLE_SUBSTRING_FALLBACK=true
GRAPH_SUBSTRING_FALLBACK_LIMIT=20
GRAPH_DESCRIPTION_FALLBACK_MIN_TERM_LENGTH=5
GRAPH_ALLOW_LEGACY_SCAN_FALLBACK=true
GRAPHSEARCH_MAX_SUB_QUERIES=3
GRAPHSEARCH_MAX_EXPANDED_QUERIES=1

# ── GraphSearch context sizing ─────────────────────────────────────────────
GRAPH_ENTITY_SEARCH_TOP_K_MULTIPLIER=4
GRAPH_RELATIONSHIP_SEARCH_TOP_K_MULTIPLIER=3
GRAPH_CONTEXT_ENTITY_TOP_K_MULTIPLIER=2
GRAPH_CONTEXT_RELATIONSHIP_TOP_K_MULTIPLIER=3
GRAPH_CONTEXT_DESCRIPTION_MAX_CHARS=1200

# ── GraphSearch scoring weights ────────────────────────────────────────────
GRAPH_SCORE_EXACT_NAME=100
GRAPH_SCORE_EXACT_ALIAS=95
GRAPH_SCORE_PARTIAL_ALIAS=90
GRAPH_SCORE_PARTIAL_NAME=80
GRAPH_SCORE_SEARCH_TEXT=70
GRAPH_SCORE_DESCRIPTION=60

# ── Evaluation / RAGAS ─────────────────────────────────────────────────────
RAGAS_SCORE_MAX_WORKERS=2
RAGAS_SCORE_MAX_RETRIES=10
RAGAS_SCORE_MAX_WAIT_SECONDS=120
RAGAS_SCORE_TIMEOUT_SECONDS=300
RAGAS_LLM_TEMPERATURE=0.0
QDRANT_UPSERT_BATCH_SIZE=1000
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
CX_API_KEY=
RAGAS_EMBEDDING_API_KEY=
RAGAS_EMBEDDING_MODEL=nvidia/llama-3.2-nemoretriever-300m-embed-v1
RAGAS_EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
RAGAS_EMBEDDING_DELAY_SECONDS=0.1

# ── Docker Compose local storage ───────────────────────────────────────────
KGSAUTO_DOCKER_DATA_DIR=./data/docker
NEO4J_AUTH=neo4j/12345678

# ── Legacy aliases still supported ─────────────────────────────────────────
# OPENAI_API_KEY may be used when OPENAI_COMPATIBLE_API_KEY is unset.
# CX_API_KEY may be used when OPENAI_COMPATIBLE_API_KEY and OPENAI_API_KEY are unset.
# NVIDIA_API_KEY may be used when RAGAS_EMBEDDING_API_KEY is unset.
# NVIDIA_EMBED_MODEL may be used when RAGAS_EMBEDDING_MODEL is unset.
# NVIDIA_BASE_URL may be used when RAGAS_EMBEDDING_BASE_URL is unset.
